# ── Zscaler OneAPI Credentials ─────────────────────────────
ZSCALER_CLIENT_ID=ipm2ol7odg7hp
ZSCALER_CLIENT_SECRET=1rwNOw6CsWtMukF7zvOz83QyEv8vaPA0M688NS4b
ZSCALER_VANITY_DOMAIN=securitygeekio
ZSCALER_CUSTOMER_ID=216196257331281920
ZSCALER_CLOUD=production

# Use existing secret if you have one; comment out for CreateNew
# ZSCALER_SECRET_NAME=zscaler/mcp/credentials

# ── Container image override (TEMPORARY for AgentCore zscaler-mode testing) ───
# Points the AgentCore Runtime at a custom-built image in the dev account's
# ECR instead of the AWS Marketplace tag. This image contains the auth.py
# container-side credential fallback so 'zscaler' mode works in the Sandbox
# playground. Comment this line out (or delete it) to go back to the
# Marketplace image once the change is published as <new-version>-bedrock.
ZSCALER_MCP_IMAGE_URI=202719523534.dkr.ecr.us-east-1.amazonaws.com/zscaler/zscaler-mcp-server:latest

# ── MCP server settings ────────────────────────────────────
ZSCALER_MCP_AUTH_MODE=zscaler
ZSCALER_MCP_WRITE_ENABLED=true
ZSCALER_MCP_WRITE_TOOLS=zpa_*,zia_*,zdx_*
ZSCALER_MCP_LOG_TOOL_CALLS=true
ZSCALER_MCP_ALLOWED_HOSTS=127.0.0.1:*,localhost:*
ZSCALER_MCP_ALLOW_HTTP=true
ZSCALER_MCP_AUTH_ALGORITHMS=RS256

# ── AgentCore Gateway ──────────────────────────────────────
ENABLE_AGENTCORE_GATEWAY=true
GATEWAY_MODE=create

# Auth0 — Gateway inbound (what you set up in Auth0)
GATEWAY_INBOUND_DISCOVERY_URL=https://securitygeekio.ca.auth0.com/.well-known/jwks.json
GATEWAY_INBOUND_ISSUER=https://securitygeekio.ca.auth0.com/
GATEWAY_INBOUND_ALLOWED_AUDIENCE=urn:zscaler-mcp:gateway
GATEWAY_OAUTH_CLIENT_ID=xNWVAsoQZ2jQtg7t9NHbj0SJBHxO5Aze

# ── AWS targeting ──────────────────────────────────────────
AWS_REGION=us-east-1
AWS_STACK_NAME=zscaler-mcp-agentcore