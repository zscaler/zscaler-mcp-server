# =============================================================================
# MCP Client Authentication (Layer 1: who can use this MCP server?)
# =============================================================================
# By default, authentication is DISABLED for backward compatibility.
# Enable it when the server is exposed over HTTP (SSE or streamable-http).
# Auth does NOT apply to stdio transport (local process isolation is sufficient).

#ZSCALER_MCP_AUTH_ENABLED=false

# Auth mode: jwt | zscaler | api-key | oauth-proxy
# See documentation for details on each mode.
#ZSCALER_MCP_AUTH_MODE=jwt

# --- Mode: jwt (External IdP via JWKS) ---
# Works with Okta, PingOne, Azure AD, Auth0, Keycloak, AWS Cognito, Google, etc.
# The server fetches the IdP's public keys once and validates tokens locally.
#ZSCALER_MCP_AUTH_JWKS_URI=https://your-idp.com/.well-known/jwks.json
#ZSCALER_MCP_AUTH_ISSUER=https://your-idp.com
#ZSCALER_MCP_AUTH_AUDIENCE=zscaler-mcp-server
#ZSCALER_MCP_AUTH_ALGORITHMS=RS256,ES256

# --- Mode: zscaler (Zscaler OneAPI Credentials) ---
# MCP client sends Basic Auth with Zscaler API client_id:client_secret.
# Server validates against Zscaler's /oauth2/v1/token endpoint.
# Uses ZSCALER_VANITY_DOMAIN and ZSCALER_CLOUD from the section below.

# --- Mode: api-key (Simple Shared Secret) ---
# Generate a random key and share it with authorized MCP clients.
# Client sends: Authorization: Bearer <api-key>
#ZSCALER_MCP_AUTH_API_KEY=sk-your-secret-key-here

# --- Mode: oauth-proxy (Full MCP Spec Compliance — Phase 2) ---
#ZSCALER_MCP_AUTH_AUTHORIZATION_URL=https://your-idp.com/oauth/authorize
#ZSCALER_MCP_AUTH_TOKEN_URL=https://your-idp.com/oauth/token
#ZSCALER_MCP_AUTH_OAUTH_CLIENT_ID=your-app-client-id
#ZSCALER_MCP_AUTH_OAUTH_CLIENT_SECRET=your-app-client-secret
#ZSCALER_MCP_AUTH_BASE_URL=https://your-mcp-server.example.com:8000

# --- Host header validation (streamable-http / SSE on EC2 or public URLs) ---
# When exposed publicly, clients send Host: <public-ip>:8000. The MCP SDK rejects
# unknown hosts by default (421 Misdirected Request). Set one of:
#ZSCALER_MCP_DISABLE_HOST_VALIDATION=true
#ZSCALER_MCP_ALLOWED_HOSTS=34.201.19.115:*,localhost:*

# --- HTTPS / TLS (streamable-http / SSE) ---
# HTTPS is REQUIRED by default for non-localhost deployments.
# Set both CERTFILE and KEYFILE to enable HTTPS. The server auto-detects TLS when
# both files exist and switches uvicorn to SSL mode.
#ZSCALER_MCP_TLS_CERTFILE=/path/to/cert.pem
#ZSCALER_MCP_TLS_KEYFILE=/path/to/key.pem
#ZSCALER_MCP_TLS_KEYFILE_PASSWORD=optional-key-password
#ZSCALER_MCP_TLS_CA_CERTS=/path/to/ca-bundle.pem

# To explicitly allow plaintext HTTP on non-localhost (e.g. behind a reverse proxy,
# ZPA overlay, or on a trusted L3 network), set:
#ZSCALER_MCP_ALLOW_HTTP=true

# --- Source IP access control ---
# Restrict which client IPs can connect. Supports individual IPs, CIDR notation,
# and wildcard (0.0.0.0/0). When unset, source IP filtering is disabled and
# deferred to upstream controls (firewall, AWS Security Groups, etc.).
#ZSCALER_MCP_ALLOWED_SOURCE_IPS=10.0.0.0/8,172.16.0.5

# --- Destructive action confirmation ---
# Delete operations use cryptographic confirmation tokens (HMAC-SHA256) by default.
# Set to true to skip confirmations in automated testing or CI/CD.
#ZSCALER_MCP_SKIP_CONFIRMATIONS=false

# =============================================================================
# Zscaler OneAPI Credentials (Layer 2: how the server talks to Zscaler APIs)
# =============================================================================
# Required: Get these from your Zidentity console
ZSCALER_CLIENT_ID=your-client-id
ZSCALER_CLIENT_SECRET=your-client-secret
ZSCALER_CUSTOMER_ID=your-customer-id
ZSCALER_VANITY_DOMAIN=your-vanity-domain

# =============================================================================
# Optional: OneAPI Cloud Configuration
# =============================================================================
# This parameter is optional and only required when interacting with the Zidentity "beta" cloud
# The only supported value is "beta"

#ZSCALER_CLOUD=your-cloud-name